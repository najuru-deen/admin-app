<div class="flex flex-col items-center justify-center py-24 text-center">
  <div class="text-8xl font-black text-red-100 mb-4">500</div>
  <h2 class="text-xl font-semibold text-gray-700 mb-2">Server Error</h2>
  <p class="text-gray-400 mb-2">Something went wrong on the server.</p>
  <% if (locals.message) { %>
    <code class="text-xs text-red-600 bg-red-50 border border-red-200 px-3 py-2 rounded-lg mb-6"><%= message %></code>
  <% } %>
  <a href="/" class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg text-sm">Go to Dashboard</a>
</div>
