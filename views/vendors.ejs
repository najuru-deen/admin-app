<!-- Filters -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-5">
  <form method="GET" action="/vendors" class="flex flex-wrap gap-3 items-end">
    <div>
      <label class="block text-xs text-gray-500 mb-1">Search</label>
      <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Name or mobile..."
        class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 w-48" />
    </div>
    <div>
      <label class="block text-xs text-gray-500 mb-1">Status</label>
      <select name="status" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
        <option value="">All Status</option>
        <option value="pending"  <%= filters.status === 'pending'  ? 'selected' : '' %>>Pending</option>
        <option value="approved" <%= filters.status === 'approved' ? 'selected' : '' %>>Approved</option>
        <option value="rejected" <%= filters.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
      </select>
    </div>
    <div>
      <label class="block text-xs text-gray-500 mb-1">Tier</label>
      <select name="tier" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
        <option value="">All Tiers</option>
        <option value="basic"    <%= filters.tier === 'basic'    ? 'selected' : '' %>>Basic</option>
        <option value="silver"   <%= filters.tier === 'silver'   ? 'selected' : '' %>>Silver</option>
        <option value="gold"     <%= filters.tier === 'gold'     ? 'selected' : '' %>>Gold</option>
        <option value="platinum" <%= filters.tier === 'platinum' ? 'selected' : '' %>>Platinum</option>
      </select>
    </div>
    <div>
      <label class="block text-xs text-gray-500 mb-1">City</label>
      <select name="city" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
        <option value="">All Cities</option>
        <% for (const c of cities) { %>
          <option value="<%= c.id %>" <%= filters.city == c.id ? 'selected' : '' %>><%= c.name %></option>
        <% } %>
      </select>
    </div>
    <div>
      <label class="block text-xs text-gray-500 mb-1">Category</label>
      <select name="category" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
        <option value="">All Categories</option>
        <% for (const c of categories) { %>
          <option value="<%= c.id %>" <%= filters.category == c.id ? 'selected' : '' %>><%= c.name %></option>
        <% } %>
      </select>
    </div>
    <div class="flex gap-2">
      <button type="submit" class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm rounded-lg transition-colors">Filter</button>
      <a href="/vendors" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm rounded-lg transition-colors">Clear</a>
    </div>
    <a href="/vendors/add" class="ml-auto px-4 py-2 bg-green-600 hover:bg-green-700 text-white text-sm rounded-lg transition-colors flex items-center gap-1">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Add Vendor
    </a>
  </form>
</div>

<!-- Table -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
  <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
    <span class="text-sm text-gray-600"><span class="font-medium"><%= pagination.total %></span> vendors found</span>
  </div>

  <% if (vendors.length === 0) { %>
    <div class="p-12 text-center text-gray-400">
      <p class="text-lg mb-2">No vendors found</p>
      <p class="text-sm">Try adjusting your filters.</p>
    </div>
  <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-xs text-gray-500 uppercase tracking-wide">
          <tr>
            <th class="px-5 py-3 text-left">Vendor</th>
            <th class="px-5 py-3 text-left">Category</th>
            <th class="px-5 py-3 text-left">City</th>
            <th class="px-5 py-3 text-left">Mobile</th>
            <th class="px-5 py-3 text-left">Tier</th>
            <th class="px-5 py-3 text-left">Status</th>
            <th class="px-5 py-3 text-left">Badges</th>
            <th class="px-5 py-3 text-left">Registered</th>
            <th class="px-5 py-3 text-left">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% for (const v of vendors) { %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-5 py-3">
                <div class="flex items-center gap-2">
                  <div class="w-8 h-8 rounded-lg bg-indigo-100 text-indigo-700 flex items-center justify-center text-sm font-semibold shrink-0">
                    <%= v.name.charAt(0) %>
                  </div>
                  <div>
                    <a href="/vendors/<%= v.id %>" class="font-medium text-gray-800 hover:text-indigo-600"><%= v.name %></a>
                    <% if (v.rating) { %>
                      <div class="text-xs text-yellow-500">★ <%= v.rating %> (<%= v.rating_count || 0 %>)</div>
                    <% } %>
                  </div>
                </div>
              </td>
              <td class="px-5 py-3 text-gray-600"><%= v.category_name || '—' %></td>
              <td class="px-5 py-3 text-gray-600"><%= v.city_name || '—' %></td>
              <td class="px-5 py-3 text-gray-600 font-mono text-xs"><%= v.mobile %></td>
              <td class="px-5 py-3"><span class="tier-badge tier-<%= v.membership_tier %>"><%= v.membership_tier %></span></td>
              <td class="px-5 py-3"><span class="status-badge status-<%= v.status %>"><%= v.status %></span></td>
              <td class="px-5 py-3">
                <div class="flex gap-1">
                  <% if (v.is_verified)  { %><span title="Verified"  class="text-xs bg-blue-100 text-blue-700 px-1.5 py-0.5 rounded">✓</span><% } %>
                  <% if (v.is_trusted)   { %><span title="Trusted"   class="text-xs bg-green-100 text-green-700 px-1.5 py-0.5 rounded">T</span><% } %>
                  <% if (v.is_trending)  { %><span title="Trending"  class="text-xs bg-orange-100 text-orange-700 px-1.5 py-0.5 rounded">🔥</span><% } %>
                </div>
              </td>
              <td class="px-5 py-3 text-gray-400 text-xs"><%= new Date(v.created_at * 1000).toLocaleDateString('en-IN') %></td>
              <td class="px-5 py-3">
                <div class="flex items-center gap-2">
                  <a href="/vendors/<%= v.id %>" class="text-indigo-600 hover:text-indigo-800 text-xs font-medium">Edit</a>
                  <% if (v.status === 'pending') { %>
                    <form method="POST" action="/vendors/<%= v.id %>/approve" class="inline">
                      <button type="submit" class="text-green-600 hover:text-green-800 text-xs font-medium">Approve</button>
                    </form>
                  <% } %>
                  <form method="POST" action="/vendors/<%= v.id %>/delete" class="inline"
                        onsubmit="return confirm('Delete vendor <%= v.name %>? This cannot be undone.')">
                    <button type="submit" class="text-red-500 hover:text-red-700 text-xs font-medium">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if (pagination.pages > 1) { %>
      <div class="px-5 py-4 border-t border-gray-100 flex items-center justify-between text-sm">
        <span class="text-gray-500">Page <%= pagination.page %> of <%= pagination.pages %></span>
        <div class="flex gap-2">
          <% if (pagination.page > 1) { %>
            <a href="?page=<%= pagination.page - 1 %>&status=<%= filters.status||'' %>&tier=<%= filters.tier||'' %>&city=<%= filters.city||'' %>&category=<%= filters.category||'' %>&search=<%= filters.search||'' %>"
               class="px-3 py-1 border border-gray-300 rounded-lg hover:bg-gray-50">← Prev</a>
          <% } %>
          <% if (pagination.page < pagination.pages) { %>
            <a href="?page=<%= pagination.page + 1 %>&status=<%= filters.status||'' %>&tier=<%= filters.tier||'' %>&city=<%= filters.city||'' %>&category=<%= filters.category||'' %>&search=<%= filters.search||'' %>"
               class="px-3 py-1 border border-gray-300 rounded-lg hover:bg-gray-50">Next →</a>
          <% } %>
        </div>
      </div>
    <% } %>
  <% } %>
</div>
