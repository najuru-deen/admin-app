<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login — VV</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap');
    * { font-family: 'Poppins', sans-serif; }

    body {
      background: linear-gradient(135deg, #ff6b35 0%, #f7c59f 15%, #ffe66d 30%, #ff6b6b 45%, #c44dff 60%, #ff6b35 75%, #f7c59f 90%, #ffe66d 100%);
      background-size: 400% 400%;
      animation: gradientShift 8s ease infinite;
    }
    @keyframes gradientShift {
      0%   { background-position: 0% 50%; }
      50%  { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    /* Floating emojis */
    .float-emoji {
      position: fixed;
      font-size: 1.8rem;
      animation: floatUp linear infinite;
      pointer-events: none;
      user-select: none;
      opacity: 0;
    }
    @keyframes floatUp {
      0%   { transform: translateY(100vh) rotate(0deg); opacity: 0; }
      10%  { opacity: 1; }
      90%  { opacity: 0.8; }
      100% { transform: translateY(-120px) rotate(360deg); opacity: 0; }
    }

    /* Confetti dots */
    .confetti {
      position: fixed;
      width: 8px;
      height: 8px;
      border-radius: 2px;
      animation: confettiFall linear infinite;
      pointer-events: none;
    }
    @keyframes confettiFall {
      0%   { transform: translateY(-20px) rotate(0deg); opacity: 1; }
      100% { transform: translateY(110vh) rotate(720deg); opacity: 0.3; }
    }

    /* Twinkling stars */
    .twinkle {
      position: fixed;
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: white;
      animation: twinkleAnim ease-in-out infinite;
      pointer-events: none;
    }
    @keyframes twinkleAnim {
      0%, 100% { opacity: 0.1; transform: scale(0.8); }
      50%       { opacity: 1;   transform: scale(1.4); }
    }

    /* Card shimmer */
    .card-shimmer {
      background: rgba(255,255,255,0.92);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      box-shadow: 0 25px 60px rgba(196,77,255,0.25), 0 8px 24px rgba(255,107,53,0.2), 0 0 0 1px rgba(255,255,255,0.6);
    }

    /* Logo pulse ring */
    .logo-ring {
      animation: ringPulse 2s ease-in-out infinite;
    }
    @keyframes ringPulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(255,107,53,0.6), 0 0 0 0 rgba(196,77,255,0.4); }
      50%       { box-shadow: 0 0 0 12px rgba(255,107,53,0), 0 0 0 24px rgba(196,77,255,0); }
    }

    /* Garland top border */
    .garland-top {
      background: linear-gradient(90deg, #ff6b35, #ffe66d, #c44dff, #ff6b6b, #ffe66d, #ff6b35);
      height: 4px;
      border-radius: 16px 16px 0 0;
    }

    .input-festive:focus {
      outline: none;
      border-color: transparent;
      box-shadow: 0 0 0 2px #ff6b35, 0 0 0 4px rgba(196,77,255,0.3);
    }

    .btn-festive {
      background: linear-gradient(135deg, #ff6b35, #c44dff, #ff6b6b);
      background-size: 200% 200%;
      animation: btnGradient 3s ease infinite;
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .btn-festive:hover {
      transform: translateY(-1px);
      box-shadow: 0 8px 20px rgba(196,77,255,0.45);
    }
    .btn-festive:active { transform: translateY(0); }
    @keyframes btnGradient {
      0%   { background-position: 0% 50%; }
      50%  { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    .celebrate-text {
      background: linear-gradient(90deg, #ff6b35, #c44dff, #ff6b6b, #ffe66d, #ff6b35);
      background-size: 300% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: textShine 3s linear infinite;
    }
    @keyframes textShine {
      to { background-position: 300% center; }
    }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4 relative overflow-hidden">

  <!-- Twinkling stars -->
  <script>
    for (let i = 0; i < 40; i++) {
      const s = document.createElement('div');
      s.className = 'twinkle';
      s.style.cssText = `left:${Math.random()*100}vw;top:${Math.random()*100}vh;animation-delay:${Math.random()*3}s;animation-duration:${1.5+Math.random()*2}s;opacity:${0.3+Math.random()*0.7}`;
      document.body.appendChild(s);
    }
  </script>

  <!-- Confetti -->
  <script>
    const confettiColors = ['#ff6b35','#ffe66d','#c44dff','#ff6b6b','#4ecdc4','#45b7d1','#96ceb4','#ffeaa7'];
    for (let i = 0; i < 30; i++) {
      const c = document.createElement('div');
      c.className = 'confetti';
      c.style.cssText = `left:${Math.random()*100}vw;background:${confettiColors[Math.floor(Math.random()*confettiColors.length)]};animation-delay:${Math.random()*6}s;animation-duration:${4+Math.random()*4}s;border-radius:${Math.random()>0.5?'50%':'2px'}`;
      document.body.appendChild(c);
    }
  </script>

  <!-- Floating celebration emojis -->
  <script>
    const emojis = ['💒','🎊','🌸','✨','🎉','🥂','💐','🎀','🪔','🌺','💍','🎁','🎶','🪅','🌼','🎆','🎇','🧨'];
    emojis.forEach((emoji, i) => {
      const el = document.createElement('div');
      el.className = 'float-emoji';
      el.textContent = emoji;
      el.style.cssText = `left:${5 + (i * 5.5) % 90}vw;animation-delay:${i * 0.8}s;animation-duration:${8+Math.random()*6}s;font-size:${1.4+Math.random()*1}rem`;
      document.body.appendChild(el);
    });
  </script>

  <!-- Main card -->
  <div class="w-full max-w-md relative z-10">

    <!-- Logo & Title -->
    <div class="text-center mb-6">
      <div class="relative inline-block mb-4">
        <div class="logo-ring inline-flex items-center justify-center w-16 h-16 rounded-2xl shadow-lg"
             style="background: linear-gradient(135deg, #ff6b35, #c44dff);">
          <span class="text-white text-3xl">🏠</span>
        </div>
        <!-- sparkle dots -->
        <span class="absolute -top-1 -right-1 text-lg" style="animation: twinkleAnim 1.2s ease-in-out infinite;">✨</span>
        <span class="absolute -bottom-1 -left-1 text-sm" style="animation: twinkleAnim 1.8s ease-in-out infinite 0.5s;">🌟</span>
      </div>
      <h1 class="text-3xl font-extrabold celebrate-text leading-tight">Veetla Visesanga</h1>
      <p class="text-white/90 text-sm font-medium mt-1 drop-shadow">🎊 Celebrations &amp; Vendor Admin 🎊</p>
      <div class="flex justify-center gap-1 mt-2 text-lg">
        <span>💒</span><span>🌸</span><span>🎉</span><span>🪔</span><span>🎊</span>
      </div>
    </div>

    <% const dbErr = locals.dbError; %>
    <% if (dbErr) { %>
      <!-- DB not configured -->
      <div class="card-shimmer rounded-2xl overflow-hidden">
        <div class="garland-top"></div>
        <div class="p-6">
          <div class="flex items-start gap-3 mb-4">
            <div class="w-9 h-9 bg-amber-100 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-amber-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
            </div>
            <div>
              <h2 class="text-base font-bold text-amber-900">Database not configured</h2>
              <p class="text-sm text-amber-800 mt-0.5"><%= dbErr %></p>
            </div>
          </div>
          <div class="bg-amber-50 rounded-xl p-4 text-sm space-y-1.5 mb-4">
            <p class="font-semibold text-gray-700">Setup steps:</p>
            <ol class="list-decimal list-inside space-y-1 text-gray-600 text-xs">
              <li>Go to <strong>supabase.com</strong> → your project → <strong>Settings → API</strong></li>
              <li>Copy the <strong>Project URL</strong> and <strong>anon key</strong></li>
              <li>Open <code class="bg-white px-1 rounded">admin-app/data/config.json</code></li>
              <li>Set <code class="bg-white px-1 rounded">supabase_url</code> and <code class="bg-white px-1 rounded">supabase_key</code></li>
              <li>Restart the server: <code class="bg-white px-1 rounded">npm start</code></li>
            </ol>
          </div>
          <p class="text-xs text-amber-700 text-center">Login will be available once the database is connected 🙏</p>
        </div>
      </div>
    <% } else { %>
      <!-- Login card -->
      <div class="card-shimmer rounded-2xl overflow-hidden">
        <div class="garland-top"></div>
        <div class="p-8">

          <!-- Card header -->
          <div class="text-center mb-6">
            <h2 class="text-xl font-bold text-gray-800">Welcome Back! 🙏</h2>
            <p class="text-sm text-gray-500 mt-0.5">Sign in to manage your celebrations</p>
          </div>

          <!-- Festive divider -->
          <div class="flex items-center gap-2 mb-5">
            <div class="flex-1 h-px bg-gradient-to-r from-transparent via-pink-300 to-transparent"></div>
            <span class="text-sm">🌸 🎊 🌸</span>
            <div class="flex-1 h-px bg-gradient-to-r from-transparent via-purple-300 to-transparent"></div>
          </div>

          <% const msgs = locals.error || []; %>
          <% if (msgs.length > 0) { %>
            <div class="mb-4 p-3 bg-red-50 border border-red-200 text-red-700 rounded-xl text-sm flex items-center gap-2">
              <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
              <%= msgs[0] %>
            </div>
          <% } %>

          <form method="POST" action="/login" class="space-y-4">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5" for="username">
                👤 Username
              </label>
              <input
                type="text" id="username" name="username" required autofocus
                class="input-festive w-full px-4 py-3 border-2 border-purple-200 rounded-xl text-sm bg-white/80 placeholder-gray-400 transition focus:bg-white"
                placeholder="Enter your username"
              />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5" for="password">
                🔐 Password
              </label>
              <input
                type="password" id="password" name="password" required
                class="input-festive w-full px-4 py-3 border-2 border-purple-200 rounded-xl text-sm bg-white/80 placeholder-gray-400 transition focus:bg-white"
                placeholder="••••••••"
              />
            </div>
            <button type="submit" class="btn-festive w-full py-3 text-white font-bold rounded-xl text-sm tracking-wide shadow-lg">
              🎉 Sign In &amp; Celebrate!
            </button>
          </form>

          <!-- Bottom decoration -->
          <div class="mt-6 pt-4 border-t border-gray-100 text-center">
            <div class="flex justify-center gap-2 mb-2 text-base">
              <span title="Wedding">💒</span>
              <span title="Home Gathering">🏠</span>
              <span title="Festival">🪔</span>
              <span title="Celebration">🎊</span>
              <span title="Flowers">🌺</span>
              <span title="Drinks">🥂</span>
            </div>
            <p class="text-gray-400 text-xs">Default: admin / admin123</p>
            <p class="text-xs mt-1" style="background: linear-gradient(90deg,#ff6b35,#c44dff,#ff6b35); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">
              Every celebration deserves the best vendors ✨
            </p>
          </div>
        </div>
      </div>
    <% } %>

    <!-- Footer tagline -->
    <p class="text-center text-white/70 text-xs mt-5 drop-shadow">
      🏠 Veetla Visesanga — Where Every Home Celebration Shines 🌟
    </p>
  </div>

</body>
</html>
