<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login — VV</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-900 flex items-center justify-center p-4">

  <div class="w-full max-w-md">
    <!-- Logo -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-14 h-14 bg-indigo-600 rounded-2xl mb-4 shadow-lg">
        <span class="text-white text-2xl font-bold">V</span>
      </div>
      <h1 class="text-2xl font-bold text-white">VV Admin</h1>
      <p class="text-slate-400 text-sm mt-1">Veetla Visesanga Control Panel</p>
    </div>

    <% const dbErr = locals.dbError; %>
    <% if (dbErr) { %>
      <!-- DB not configured — show setup instructions, hide login form -->
      <div class="bg-amber-50 border border-amber-300 rounded-2xl shadow-2xl p-6">
        <div class="flex items-start gap-3 mb-4">
          <div class="w-8 h-8 bg-amber-100 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-amber-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
          </div>
          <div>
            <h2 class="text-base font-bold text-amber-900">Database not configured</h2>
            <p class="text-sm text-amber-800 mt-1"><%= dbErr %></p>
          </div>
        </div>

        <div class="bg-white rounded-xl p-4 text-sm space-y-2 mb-4">
          <p class="font-semibold text-gray-700">How to get your Supabase password:</p>
          <ol class="list-decimal list-inside space-y-1 text-gray-600">
            <li>Go to <strong>supabase.com</strong> → your project</li>
            <li>Click <strong>Settings → Database</strong></li>
            <li>Scroll to <strong>Connection string</strong> → choose <strong>Transaction pooler</strong></li>
            <li>Copy the URI — it contains your password</li>
            <li>Open <code class="bg-gray-100 px-1 rounded text-xs">admin-app/data/config.json</code> and replace <code class="bg-gray-100 px-1 rounded text-xs">[PASSWORD]</code></li>
            <li>Restart the server: <code class="bg-gray-100 px-1 rounded text-xs">npm start</code></li>
          </ol>
        </div>

        <div class="bg-slate-800 rounded-lg p-3 text-xs font-mono text-green-300 break-all">
          postgresql://postgres.biplrucsvasbaxwzqsod:<span class="text-yellow-300 font-bold">[YOUR-PASSWORD]</span>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
        </div>

        <p class="text-xs text-amber-700 mt-3 text-center">Login will be available once the database is connected.</p>
      </div>
    <% } else { %>
      <!-- Normal login card -->
      <div class="bg-white rounded-2xl shadow-2xl p-8">
        <h2 class="text-xl font-semibold text-gray-800 mb-6">Sign in</h2>

        <% const msgs = locals.error || []; %>
        <% if (msgs.length > 0) { %>
          <div class="mb-4 p-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
            <%= msgs[0] %>
          </div>
        <% } %>

        <form method="POST" action="/login" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="username">Username</label>
            <input
              type="text" id="username" name="username" required autofocus
              class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition"
              placeholder="admin"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="password">Password</label>
            <input
              type="password" id="password" name="password" required
              class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition"
              placeholder="••••••••"
            />
          </div>
          <button
            type="submit"
            class="w-full py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg text-sm transition-colors"
          >
            Sign in
          </button>
        </form>

        <p class="text-center text-gray-400 text-xs mt-6">Default: admin / admin123</p>
      </div>
    <% } %>
  </div>

</body>
</html>
