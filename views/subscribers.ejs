<!-- Stats -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-5">
  <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
    <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Total Records</p>
    <p class="text-2xl font-bold text-gray-800"><%= stats.total %></p>
  </div>
  <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
    <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Paid</p>
    <p class="text-2xl font-bold text-green-600"><%= stats.paid %></p>
  </div>
  <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
    <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Active</p>
    <p class="text-2xl font-bold text-indigo-600"><%= stats.active %></p>
  </div>
  <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
    <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Revenue</p>
    <p class="text-2xl font-bold text-purple-600">₹<%= Number(stats.revenue).toLocaleString('en-IN') %></p>
  </div>
</div>

<!-- Add Membership + Filters row -->
<div class="flex flex-wrap gap-4 mb-5">
  <!-- Filters -->
  <div class="flex-1 bg-white rounded-xl shadow-sm border border-gray-100 p-4">
    <form method="GET" action="/subscribers" class="flex flex-wrap gap-3 items-end">
      <div>
        <label class="block text-xs text-gray-500 mb-1">Search</label>
        <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Vendor name or mobile..."
          class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 w-48" />
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Tier</label>
        <select name="tier" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
          <option value="">All Tiers</option>
          <option value="basic"    <%= filters.tier === 'basic'    ? 'selected' : '' %>>Basic</option>
          <option value="silver"   <%= filters.tier === 'silver'   ? 'selected' : '' %>>Silver</option>
          <option value="gold"     <%= filters.tier === 'gold'     ? 'selected' : '' %>>Gold</option>
          <option value="platinum" <%= filters.tier === 'platinum' ? 'selected' : '' %>>Platinum</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Payment</label>
        <select name="payment_status" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
          <option value="">All</option>
          <option value="paid"    <%= filters.payment_status === 'paid'    ? 'selected' : '' %>>Paid</option>
          <option value="pending" <%= filters.payment_status === 'pending' ? 'selected' : '' %>>Pending</option>
        </select>
      </div>
      <div class="flex gap-2">
        <button type="submit" class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm rounded-lg">Filter</button>
        <a href="/subscribers" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm rounded-lg">Clear</a>
      </div>
    </form>
  </div>

  <!-- Add Membership -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
    <h3 class="text-xs font-semibold text-gray-700 mb-3">Add Membership</h3>
    <form method="POST" action="/subscribers/add" class="flex flex-wrap gap-2 items-end">
      <div>
        <label class="block text-xs text-gray-500 mb-1">Vendor ID</label>
        <input type="text" name="vendor_id" required placeholder="Vendor UUID..." class="px-2 py-1.5 border border-gray-300 rounded text-xs w-48 focus:outline-none focus:ring-1 focus:ring-indigo-500" />
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Tier</label>
        <select name="tier" required class="px-2 py-1.5 border border-gray-300 rounded text-xs focus:outline-none focus:ring-1 focus:ring-indigo-500">
          <option value="silver">Silver</option>
          <option value="gold">Gold</option>
          <option value="platinum">Platinum</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Payment</label>
        <select name="payment_status" class="px-2 py-1.5 border border-gray-300 rounded text-xs focus:outline-none focus:ring-1 focus:ring-indigo-500">
          <option value="paid">Paid</option>
          <option value="pending">Pending</option>
        </select>
      </div>
      <button type="submit" class="px-3 py-1.5 bg-green-600 hover:bg-green-700 text-white text-xs font-medium rounded transition-colors">Add</button>
    </form>
  </div>
</div>

<!-- Table -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
  <div class="px-5 py-4 border-b border-gray-100">
    <span class="text-sm text-gray-600"><span class="font-medium"><%= pagination.total %></span> membership records</span>
  </div>

  <% if (memberships.length === 0) { %>
    <div class="p-12 text-center text-gray-400">No membership records found.</div>
  <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-xs text-gray-500 uppercase tracking-wide">
          <tr>
            <th class="px-5 py-3 text-left">Vendor</th>
            <th class="px-5 py-3 text-left">Tier</th>
            <th class="px-5 py-3 text-left">Amount</th>
            <th class="px-5 py-3 text-left">Payment</th>
            <th class="px-5 py-3 text-left">Ref</th>
            <th class="px-5 py-3 text-left">Expires</th>
            <th class="px-5 py-3 text-left">Created</th>
            <th class="px-5 py-3 text-left">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% for (const m of memberships) { %>
            <% const isExpired = m.expires_at && m.expires_at < now; %>
            <tr class="hover:bg-gray-50 <%= isExpired ? 'opacity-60' : '' %>">
              <td class="px-5 py-3">
                <a href="/vendors/<%= m.vendor_id %>" class="font-medium text-gray-800 hover:text-indigo-600"><%= m.vendor_name || '—' %></a>
                <div class="text-xs text-gray-400"><%= m.category_name %> • <%= m.city_name %></div>
              </td>
              <td class="px-5 py-3"><span class="tier-badge tier-<%= m.tier %>"><%= m.tier %></span></td>
              <td class="px-5 py-3 font-medium text-gray-700">₹<%= Number(m.amount || 0).toLocaleString('en-IN') %></td>
              <td class="px-5 py-3">
                <span class="px-2 py-0.5 rounded-full text-xs font-medium <%= m.payment_status === 'paid' ? 'bg-green-100 text-green-700' : 'bg-amber-100 text-amber-700' %>">
                  <%= m.payment_status %>
                </span>
              </td>
              <td class="px-5 py-3 text-gray-400 font-mono text-xs"><%= m.payment_ref || '—' %></td>
              <td class="px-5 py-3 text-xs <%= isExpired ? 'text-red-500 font-medium' : 'text-gray-600' %>">
                <%= m.expires_at ? new Date(m.expires_at * 1000).toLocaleDateString('en-IN') : '—' %>
                <% if (isExpired) { %><span class="ml-1 text-red-400">(expired)</span><% } %>
              </td>
              <td class="px-5 py-3 text-gray-400 text-xs"><%= new Date(m.created_at * 1000).toLocaleDateString('en-IN') %></td>
              <td class="px-5 py-3">
                <div class="flex items-center gap-2 flex-wrap">
                  <% if (m.payment_status !== 'paid') { %>
                    <form method="POST" action="/subscribers/<%= m.id %>/mark-paid">
                      <button type="submit" class="text-xs text-green-600 hover:text-green-800 font-medium">Mark Paid</button>
                    </form>
                  <% } %>
                  <button type="button" onclick="showExtendModal('<%= m.id %>')" class="text-xs text-indigo-600 hover:text-indigo-800 font-medium">Extend</button>
                  <form method="POST" action="/subscribers/<%= m.id %>/delete" onsubmit="return confirm('Delete this membership record?')">
                    <button type="submit" class="text-xs text-red-500 hover:text-red-700 font-medium">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if (pagination.pages > 1) { %>
      <div class="px-5 py-4 border-t border-gray-100 flex items-center justify-between text-sm">
        <span class="text-gray-500">Page <%= pagination.page %> of <%= pagination.pages %></span>
        <div class="flex gap-2">
          <% if (pagination.page > 1) { %>
            <a href="?page=<%= pagination.page - 1 %>&tier=<%= filters.tier||'' %>&payment_status=<%= filters.payment_status||'' %>&search=<%= filters.search||'' %>"
               class="px-3 py-1 border border-gray-300 rounded-lg hover:bg-gray-50">← Prev</a>
          <% } %>
          <% if (pagination.page < pagination.pages) { %>
            <a href="?page=<%= pagination.page + 1 %>&tier=<%= filters.tier||'' %>&payment_status=<%= filters.payment_status||'' %>&search=<%= filters.search||'' %>"
               class="px-3 py-1 border border-gray-300 rounded-lg hover:bg-gray-50">Next →</a>
          <% } %>
        </div>
      </div>
    <% } %>
  <% } %>
</div>

<!-- Extend Modal -->
<div id="extendModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-xl shadow-xl w-full max-w-sm p-6">
    <h3 class="text-base font-semibold text-gray-800 mb-4">Extend Membership</h3>
    <form id="extendForm" method="POST">
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Extend by (days)</label>
        <input type="number" name="days" value="365" min="1" class="form-input" />
      </div>
      <div class="flex gap-3">
        <button type="submit" class="flex-1 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg text-sm">Extend</button>
        <button type="button" onclick="document.getElementById('extendModal').classList.add('hidden')"
          class="flex-1 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-lg text-sm">Cancel</button>
      </div>
    </form>
  </div>
</div>
<script>
function showExtendModal(id) {
  document.getElementById('extendForm').action = '/subscribers/' + id + '/extend';
  document.getElementById('extendModal').classList.remove('hidden');
}
</script>
