<%
  const settingsTabs = [
    { href: '/settings/cities',     label: 'Cities & Regions', icon: '🗺️' },
    { href: '/settings/categories', label: 'Categories',        icon: '🏷️' },
    { href: '/settings/system',     label: 'System',            icon: '⚙️' },
  ];
  const activeTab = '/settings/system';
%>

<!-- Sub-tabs -->
<div class="flex gap-1 bg-white rounded-xl border border-gray-100 shadow-sm p-1 mb-6 w-fit">
  <% settingsTabs.forEach(tab => { %>
    <a href="<%= tab.href %>"
      class="px-4 py-2 rounded-lg text-sm font-medium transition-colors <%= tab.href === activeTab ? 'bg-indigo-600 text-white shadow-sm' : 'text-gray-500 hover:bg-gray-100' %>">
      <%= tab.icon %> <%= tab.label %>
    </a>
  <% }) %>
</div>

<div class="max-w-sm">
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 text-center">
    <div class="w-14 h-14 bg-indigo-100 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-7 h-7 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
      </svg>
    </div>
    <h2 class="text-lg font-semibold text-gray-800 mb-1">Confirm Your Identity</h2>
    <p class="text-sm text-gray-500 mb-6">Enter your password to access System Settings.</p>

    <form method="POST" action="/settings/system/verify" class="space-y-4 text-left">
      <div>
        <label class="form-label">Password for <span class="text-indigo-600"><%= user?.username %></span></label>
        <input type="password" name="password" required autofocus
          class="form-input" placeholder="••••••••" />
      </div>
      <button type="submit" class="w-full py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg text-sm transition-colors">
        Verify & Continue
      </button>
      <a href="/settings/cities" class="block text-center text-sm text-gray-400 hover:text-gray-600 mt-2">Cancel</a>
    </form>
  </div>
</div>
