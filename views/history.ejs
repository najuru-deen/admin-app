<%
function actionColor(action) {
  const map = {
    LOGIN: 'bg-blue-100 text-blue-700',
    LOGOUT: 'bg-gray-100 text-gray-600',
    LOGIN_FAILED: 'bg-red-100 text-red-700',
    APPROVE_VENDOR: 'bg-green-100 text-green-700',
    REJECT_VENDOR: 'bg-red-100 text-red-700',
    ADD_VENDOR: 'bg-indigo-100 text-indigo-700',
    UPDATE_VENDOR: 'bg-yellow-100 text-yellow-700',
    DELETE_VENDOR: 'bg-red-100 text-red-700',
    ADD_MEMBERSHIP: 'bg-purple-100 text-purple-700',
    MARK_PAID: 'bg-green-100 text-green-700',
    EXTEND_MEMBERSHIP: 'bg-indigo-100 text-indigo-700',
    DELETE_MEMBERSHIP: 'bg-red-100 text-red-700',
    UPDATE_DB_URL: 'bg-orange-100 text-orange-700',
    ADD_ADMIN_USER: 'bg-blue-100 text-blue-700',
    CHANGE_PASSWORD: 'bg-yellow-100 text-yellow-700',
    DELETE_ADMIN_USER: 'bg-red-100 text-red-700',
  };
  return map[action] || 'bg-gray-100 text-gray-600';
}
%>
<!-- Filters -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-5">
  <form method="GET" action="/history" class="flex flex-wrap gap-3 items-end">
    <div>
      <label class="block text-xs text-gray-500 mb-1">Action</label>
      <select name="action" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
        <option value="">All Actions</option>
        <% for (const a of actions) { %>
          <option value="<%= a.action %>" <%= filters.action === a.action ? 'selected' : '' %>><%= a.action %></option>
        <% } %>
      </select>
    </div>
    <div>
      <label class="block text-xs text-gray-500 mb-1">Admin</label>
      <select name="admin" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
        <option value="">All Admins</option>
        <% for (const a of admins) { %>
          <option value="<%= a.admin_username %>" <%= filters.admin === a.admin_username ? 'selected' : '' %>><%= a.admin_username %></option>
        <% } %>
      </select>
    </div>
    <div>
      <label class="block text-xs text-gray-500 mb-1">From</label>
      <input type="date" name="from" value="<%= filters.from || '' %>" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
    </div>
    <div>
      <label class="block text-xs text-gray-500 mb-1">To</label>
      <input type="date" name="to" value="<%= filters.to || '' %>" class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
    </div>
    <div class="flex gap-2">
      <button type="submit" class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm rounded-lg">Filter</button>
      <a href="/history" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm rounded-lg">Clear</a>
    </div>
  </form>
</div>

<!-- Log Table -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
  <div class="px-5 py-4 border-b border-gray-100">
    <span class="text-sm text-gray-600"><span class="font-medium"><%= pagination.total %></span> log entries</span>
  </div>

  <% if (logs.length === 0) { %>
    <div class="p-12 text-center text-gray-400">No activity log entries found.</div>
  <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-xs text-gray-500 uppercase tracking-wide">
          <tr>
            <th class="px-5 py-3 text-left">Date & Time</th>
            <th class="px-5 py-3 text-left">Admin</th>
            <th class="px-5 py-3 text-left">Action</th>
            <th class="px-5 py-3 text-left">Entity</th>
            <th class="px-5 py-3 text-left">Details</th>
            <th class="px-5 py-3 text-left">IP</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% for (const log of logs) { %>
            <tr class="hover:bg-gray-50">
              <td class="px-5 py-3 text-gray-500 text-xs whitespace-nowrap">
                <%= new Date(log.created_at * 1000).toLocaleString('en-IN') %>
              </td>
              <td class="px-5 py-3">
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-xs font-semibold">
                    <%= log.admin_username.charAt(0).toUpperCase() %>
                  </div>
                  <span class="font-medium text-gray-700"><%= log.admin_username %></span>
                </div>
              </td>
              <td class="px-5 py-3">
                <span class="px-2 py-0.5 rounded text-xs font-medium <%= actionColor(log.action) %>">
                  <%= log.action %>
                </span>
              </td>
              <td class="px-5 py-3 text-xs text-gray-500">
                <% if (log.entity_type) { %>
                  <span class="font-medium"><%= log.entity_type %></span>
                  <% if (log.entity_id) { %>
                    <div class="font-mono text-gray-400 truncate max-w-[100px]"><%= log.entity_id %></div>
                  <% } %>
                <% } else { %>—<% } %>
              </td>
              <td class="px-5 py-3 text-xs text-gray-500 max-w-xs">
                <% if (log.details) { %>
                  <% try { %>
                    <% const d = JSON.parse(log.details); %>
                    <div class="truncate" title="<%= log.details %>">
                      <% for (const [k, v] of Object.entries(d)) { %>
                        <span class="text-gray-400"><%= k %>:</span> <span class="text-gray-600"><%= v %></span>
                      <% } %>
                    </div>
                  <% } catch(e) { %>
                    <%= log.details %>
                  <% } %>
                <% } else { %>—<% } %>
              </td>
              <td class="px-5 py-3 text-xs text-gray-400 font-mono"><%= log.ip_address || '—' %></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if (pagination.pages > 1) { %>
      <div class="px-5 py-4 border-t border-gray-100 flex items-center justify-between text-sm">
        <span class="text-gray-500">Page <%= pagination.page %> of <%= pagination.pages %></span>
        <div class="flex gap-2">
          <% if (pagination.page > 1) { %>
            <a href="?page=<%= pagination.page - 1 %>&action=<%= filters.action||'' %>&admin=<%= filters.admin||'' %>&from=<%= filters.from||'' %>&to=<%= filters.to||'' %>"
               class="px-3 py-1 border border-gray-300 rounded-lg hover:bg-gray-50">← Prev</a>
          <% } %>
          <% if (pagination.page < pagination.pages) { %>
            <a href="?page=<%= pagination.page + 1 %>&action=<%= filters.action||'' %>&admin=<%= filters.admin||'' %>&from=<%= filters.from||'' %>&to=<%= filters.to||'' %>"
               class="px-3 py-1 border border-gray-300 rounded-lg hover:bg-gray-50">Next →</a>
          <% } %>
        </div>
      </div>
    <% } %>
  <% } %>
</div>

