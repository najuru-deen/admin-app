<% if (locals.dbError) { %>
  <div class="mb-4 p-4 bg-amber-50 border border-amber-300 text-amber-800 rounded-lg text-sm">
    <strong>Database warning:</strong> <%= dbError %>. Please configure the DB URL in <a href="/settings" class="underline font-medium">Settings</a>.
  </div>
<% } %>

<!-- Stats Grid -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <%
    const cards = [
      { label: 'Total Vendors',    value: stats.totalVendors,    color: 'indigo',  icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16' },
      { label: 'Pending Approval', value: stats.pendingVendors,  color: 'amber',   icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', link: '/vendors/pending' },
      { label: 'Active Subscribers', value: stats.activeSubscribers, color: 'green', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z' },
      { label: 'Total Revenue',    value: '₹' + stats.revenue,  color: 'purple',  icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
    ];
    const colorMap = { indigo: 'bg-indigo-50 text-indigo-700', amber: 'bg-amber-50 text-amber-700', green: 'bg-green-50 text-green-700', purple: 'bg-purple-50 text-purple-700' };
  %>
  <% for (const card of cards) { %>
    <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 <%= card.link ? 'cursor-pointer hover:shadow-md transition-shadow' : '' %>" <%= card.link ? `onclick="location.href='${card.link}'"` : '' %>>
      <div class="flex items-start justify-between">
        <div>
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1"><%= card.label %></p>
          <p class="text-2xl font-bold text-gray-800"><%= card.value %></p>
        </div>
        <div class="p-2 rounded-lg <%= colorMap[card.color] %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= card.icon %>"/>
          </svg>
        </div>
      </div>
    </div>
  <% } %>
</div>

<!-- Second row stats -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
    <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Approved</p>
    <p class="text-xl font-bold text-green-600"><%= stats.approvedVendors %></p>
  </div>
  <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
    <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Rejected</p>
    <p class="text-xl font-bold text-red-500"><%= stats.rejectedVendors %></p>
  </div>
  <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
    <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Leads Today</p>
    <p class="text-xl font-bold text-blue-600"><%= stats.leadsToday %></p>
  </div>
  <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
    <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Total Leads</p>
    <p class="text-xl font-bold text-gray-700"><%= stats.totalLeads %></p>
  </div>
</div>

<!-- Tier Breakdown + Recent Vendors -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">

  <!-- Tier Breakdown -->
  <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100">
    <h2 class="text-sm font-semibold text-gray-700 mb-4">Vendor Tiers (Approved)</h2>
    <div class="space-y-3">
      <%
        const tiers = [
          { key: 'platinum', label: 'Platinum', color: 'bg-purple-500' },
          { key: 'gold',     label: 'Gold',     color: 'bg-yellow-500' },
          { key: 'silver',   label: 'Silver',   color: 'bg-gray-400' },
          { key: 'basic',    label: 'Basic',    color: 'bg-blue-400' },
        ];
        const totalApproved = (tierBreakdown.platinum||0) + (tierBreakdown.gold||0) + (tierBreakdown.silver||0) + (tierBreakdown.basic||0) || 1;
      %>
      <% for (const t of tiers) { %>
        <div>
          <div class="flex justify-between text-xs text-gray-600 mb-1">
            <span><%= t.label %></span>
            <span class="font-medium"><%= tierBreakdown[t.key] || 0 %></span>
          </div>
          <div class="w-full bg-gray-100 rounded-full h-2">
            <div class="<%= t.color %> h-2 rounded-full" style="width: <%= Math.round(((tierBreakdown[t.key]||0)/totalApproved)*100) %>%"></div>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Recent Vendors -->
  <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-gray-100">
    <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
      <h2 class="text-sm font-semibold text-gray-700">Recent Registrations</h2>
      <a href="/vendors" class="text-xs text-indigo-600 hover:text-indigo-700 font-medium">View all →</a>
    </div>
    <div class="divide-y divide-gray-50">
      <% if (!recentVendors || recentVendors.length === 0) { %>
        <p class="p-5 text-sm text-gray-400 text-center">No vendors yet.</p>
      <% } else { %>
        <% for (const v of recentVendors) { %>
          <a href="/vendors/<%= v.id %>" class="flex items-center justify-between px-5 py-3 hover:bg-gray-50 transition-colors">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-indigo-100 flex items-center justify-center text-indigo-700 text-sm font-semibold">
                <%= v.name.charAt(0) %>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-800"><%= v.name %></p>
                <p class="text-xs text-gray-400"><%= v.category_name %> • <%= v.city_name %></p>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <span class="tier-badge tier-<%= v.membership_tier %>"><%= v.membership_tier %></span>
              <span class="status-badge status-<%= v.status %>"><%= v.status %></span>
            </div>
          </a>
        <% } %>
      <% } %>
    </div>
  </div>
</div>

<!-- Recent Leads -->
<% if (recentLeads && recentLeads.length > 0) { %>
<div class="bg-white rounded-xl shadow-sm border border-gray-100">
  <div class="px-5 py-4 border-b border-gray-100">
    <h2 class="text-sm font-semibold text-gray-700">Recent Leads</h2>
  </div>
  <table class="w-full text-sm">
    <thead class="bg-gray-50 text-xs text-gray-500 uppercase tracking-wide">
      <tr>
        <th class="px-5 py-3 text-left">Vendor</th>
        <th class="px-5 py-3 text-left">Category</th>
        <th class="px-5 py-3 text-left">Type</th>
        <th class="px-5 py-3 text-left">Mobile</th>
        <th class="px-5 py-3 text-left">Date</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-50">
      <% for (const lead of recentLeads) { %>
        <tr class="hover:bg-gray-50">
          <td class="px-5 py-3 font-medium text-gray-800"><%= lead.vendor_name || '—' %></td>
          <td class="px-5 py-3 text-gray-500"><%= lead.category_name || '—' %></td>
          <td class="px-5 py-3">
            <span class="px-2 py-0.5 rounded text-xs font-medium <%= lead.type === 'call' ? 'bg-blue-100 text-blue-700' : 'bg-green-100 text-green-700' %>">
              <%= lead.type %>
            </span>
          </td>
          <td class="px-5 py-3 text-gray-500"><%= lead.user_mobile || '—' %></td>
          <td class="px-5 py-3 text-gray-400"><%= new Date(lead.created_at * 1000).toLocaleString('en-IN') %></td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>
<% } %>
